# 数据库配置
DATABASE_URL=postgresql+asyncpg://altcoin:altcoin@localhost:5432/altcoin_nexus

# Redis配置
REDIS_URL=redis://localhost:6379/0

# 交易所配置
EXCHANGE_PRIMARY_EXCHANGE=binance
EXCHANGE_LEVERAGE=10
EXCHANGE_MAX_OPEN_TRADES=8

# Binance
EXCHANGE_BINANCE_API_KEY=
EXCHANGE_BINANCE_API_SECRET=

# OKX
EXCHANGE_OKX_API_KEY=
EXCHANGE_OKX_API_SECRET=
EXCHANGE_OKX_PASSPHRASE=

# Bybit
EXCHANGE_BYBIT_API_KEY=
EXCHANGE_BYBIT_API_SECRET=

# Gate.io
EXCHANGE_GATE_API_KEY=
EXCHANGE_GATE_API_SECRET=

# Bitget
EXCHANGE_BITGET_API_KEY=
EXCHANGE_BITGET_API_SECRET=
EXCHANGE_BITGET_PASSPHRASE=

# 风控配置
RISK_MAX_DAILY_LOSS=100
RISK_MAX_DAILY_TRADES=10
RISK_CONSECUTIVE_LOSS_PAUSE=3

# 策略配置
STRATEGY_VOL_MIN=500000
STRATEGY_DAILY_RSI_MIN=70
STRATEGY_HARD_STOP_PCT=5

# 监控配置
MONITOR_PROMETHEUS_ENABLED=true
MONITOR_PROMETHEUS_PORT=9090

# Telegram配置
TG_ENABLED=false
TG_BOT_TOKEN=
TG_CHAT_ID=

# 日志配置
NEXUS_LOG_LEVEL=INFO
NEXUS_ENVIRONMENT=development
